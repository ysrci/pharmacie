# server/Dockerfile.prod
FROM node:20-alpine

WORKDIR /app

# نسخ ملفات الاعتماديات
COPY package*.json ./
RUN npm ci --only=production

# نسخ الكود
COPY . .

# إنشاء مستخدم غير مسؤول
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

USER nodejs

EXPOSE 5000

CMD ["node", "server.js"]
