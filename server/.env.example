# server/.env.example
# نسخ هذا الملف إلى .env واملأ القيم الحقيقية
# ⚠️ لا ترفع ملف .env الحقيقي إلى GitHub أبداً!

# 🔐 JWT Secret - مهم جداً! استخدم مفتاح طويل وعشوائي
# أنشئ مفتاحاً جديداً باستخدام: openssl rand -hex 64
JWT_SECRET=your_secure_jwt_secret_here_min_64_characters_replace_with_your_generated_key

# 🌐 بيئة التشغيل (development, production, test)
NODE_ENV=development

# 🚪 منفذ السيرفر
PORT=5000

# 🗄️ قاعدة البيانات PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmacy_db
DB_USER=postgres
DB_PASSWORD=your_secure_db_password_here

# 🗺️ PostGIS (للمسافات والإحداثيات)
DB_SCHEMA=public

# 🎨 Frontend URL (لـ CORS)
FRONTEND_URL=http://localhost:5173

# 📧 إعدادات البريد الإلكتروني (للإشعارات)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@pharmacy.com

# 📊 مستوى التسجيل (error, warn, info, debug)
LOG_LEVEL=info
